{
  "name": "vestel-air-purifier-expo-app",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --go --port 8081",
    "start:tunnel": "expo start --tunnel --go",
    "start:clear": "expo start --go --port 8081 --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint ."
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-linear-gradient))"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-navigation/native": "^7.1.25",
    "@react-navigation/native-stack": "^7.6.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "jest-expo": "~54.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-preset-expo": "~54.0.10",
    "react-test-renderer": "^19.1.0"
  }
}
